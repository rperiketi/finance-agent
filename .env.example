# Existing Streamlit app (optional GPT-3.5 insight enhancement)
OPENAI_API_KEY=

# Azure OpenAI - required by langgraph_finance's categorization/analysis agents
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional: only needed if you switch retrieval/embeddings.py to AzureEmbeddingFunction
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Optional: where ChromaDB persists its local index (defaults to langgraph_finance/chroma_db)
CHROMA_PERSIST_DIR=

# Flask API (langgraph_finance/api.py)
# Port 5000 conflicts with macOS AirPlay Receiver on many Macs (it listens
# there too and can intermittently intercept requests, returning a 403
# instead of reaching Flask) — 5050 avoids that entirely.
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5050
FLASK_DEBUG=false
